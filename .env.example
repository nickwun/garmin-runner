# Copy field names only. Use `garmin-runner setup-credentials` to create .env.
GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=your-password

# Optional local Codex coaching layer. Keep the real value in .env only.
GARMIN_RUNNER_COACH_API_KEY=local-only-placeholder
GARMIN_RUNNER_BACKGROUND_PATH=/absolute/path/to/running_background.md
